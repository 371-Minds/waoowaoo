# ==================== 数据库 ====================
# Docker 模式下无需修改，docker-compose.yml 会自动覆盖
DATABASE_URL="mysql://root:waoowaoo123@localhost:3306/waoowaoo"

# ==================== 存储 ====================
# minio: S3 兼容对象存储（默认）
# local: 本地文件存储（仅开发调试）
# cos: 预留 provider（当前版本未实现）
STORAGE_TYPE=minio

# MinIO / S3 兼容存储配置
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=waoowaoo
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_FORCE_PATH_STYLE=true

# COS 配置（预留）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=

# ==================== 认证 ====================
NEXTAUTH_URL=https://localhost
NEXTAUTH_SECRET=please-change-this-to-a-random-string

# ==================== 内部密钥 ====================
CRON_SECRET=please-change-this-cron-secret
INTERNAL_TASK_TOKEN=please-change-this-task-token
API_ENCRYPTION_KEY=please-change-this-encryption-key

# ==================== Redis ====================
# Docker 模式下无需修改，docker-compose.yml 会自动覆盖
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=

# ==================== Worker 配置 ====================
WATCHDOG_INTERVAL_MS=30000
TASK_HEARTBEAT_TIMEOUT_MS=90000
QUEUE_CONCURRENCY_IMAGE=50
QUEUE_CONCURRENCY_VIDEO=50
QUEUE_CONCURRENCY_VOICE=20
QUEUE_CONCURRENCY_TEXT=50

# ==================== MCP Services (Phase 1) ====================
# Feature flag: set to 'true' to route script tasks via the MCP script server (HTTP).
# When false (default), domain services run in-process inside the text worker.
SCRIPT_MCP_ENABLED=false
# Base URL of the script MCP server (required when SCRIPT_MCP_ENABLED=true).
SCRIPT_MCP_URL=http://localhost:4001
# Port the script MCP server listens on (used when running src/mcp/script-server/index.ts).
SCRIPT_MCP_PORT=4001

# ==================== MCP Services (Phase 2) ====================
# Feature flag: set to 'true' to route image tasks via the MCP image server (HTTP).
# When false (default), image handlers run in-process inside the image worker.
IMAGE_MCP_ENABLED=false
# Base URL of the image MCP server (required when IMAGE_MCP_ENABLED=true).
IMAGE_MCP_URL=http://localhost:4002
# Port the image MCP server listens on (used when running src/mcp/image-server/index.ts).
IMAGE_MCP_PORT=4002

# Feature flag: set to 'true' to route asset-hub tasks via the MCP asset server (HTTP).
# When false (default), asset handlers run in-process inside the image worker.
ASSET_MCP_ENABLED=false
# Base URL of the asset MCP server (required when ASSET_MCP_ENABLED=true).
ASSET_MCP_URL=http://localhost:4003
# Port the asset MCP server listens on (used when running src/mcp/asset-server/index.ts).
ASSET_MCP_PORT=4003

# ==================== Bull Board (任务管理面板) ====================
BULL_BOARD_HOST=0.0.0.0
BULL_BOARD_PORT=3010
BULL_BOARD_BASE_PATH=/admin/queues
BULL_BOARD_USER=
BULL_BOARD_PASSWORD=

# ==================== 日志 ====================
LOG_UNIFIED_ENABLED=true
LOG_LEVEL=ERROR
LOG_FORMAT=json
LOG_DEBUG_ENABLED=false
LOG_AUDIT_ENABLED=true
LOG_SERVICE=waoowaoo
LOG_REDACT_KEYS=password,token,apiKey,apikey,authorization,cookie,secret,access_token,refresh_token

# ==================== 计费 ====================
BILLING_MODE=OFF

# ==================== 流式输出 ====================
LLM_STREAM_EPHEMERAL_ENABLED=true
